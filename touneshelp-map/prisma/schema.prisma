generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────
// Note: Using String instead of Enum for SQLite compatibility
// Enum will be handled at application level

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  role           String    @default("USER")    // "USER" or "ADMIN"
  language       String    @default("FR")     // "AR", "FR", or "EN"
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Password reset fields
  resetToken     String?
  resetTokenExpires DateTime?

  // Rejection reason for cases
  rejectionReason String?

  // Relations
  cases          Case[]
  statusHistory  StatusHistory[]
  notifications  Notification[]

  @@map("users")
}

// ─── CASES ────────────────────────────────────────────────────────────────────

model Case {
  id           String   @id @default(cuid())
  title        String
  description  String
  governorate  String
  city         String?
  latitude     Float?
  longitude    Float?
  status       String   @default("PENDING_REVIEW")  // CaseStatus as String
  images       String   // JSON string of image URLs
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Who submitted this case
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])

  // Relations
  contacts     CaseContact[]
  assistants   CaseAssistant[]
  statusHistory StatusHistory[]
  notifications Notification[]

  @@map("cases")
}

// ─── CASE CONTACT (the person in need) ────────────────────────────────────────

model CaseContact {
  id        String  @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  address   String?

  caseId    String
  case      Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_contacts")
}

// ─── CASE ASSISTANT (organisations / people who can help) ─────────────────────

model CaseAssistant {
  id      String  @id @default(cuid())
  name    String
  contact String

  caseId  String
  case    Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_assistants")
}

// ─── STATUS HISTORY (audit timeline) ─────────────────────────────────────────

model StatusHistory {
  id          String   @id @default(cuid())
  oldStatus   String   // CaseStatus as String
  newStatus   String   // CaseStatus as String
  note        String?
  createdAt   DateTime @default(now())

  // Which case was changed
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Which admin made the change
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id])

  @@map("status_history")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String   // NotificationType as String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Who receives the notification
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Which case triggered the notification
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
