{
  "info": {
    "name": "TounesHelp Backend API",
    "description": "Complete API documentation for the TounesHelp Next.js Backend System.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@touneshelp.tn\",\n  \"password\": \"password123\",\n  \"phone\": \"+21620123456\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.environment.set('token', pm.response.json().data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@touneshelp.tn\",\n  \"password\": \"Admin@TounesHelp2026\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Cases",
      "item": [
        {
          "name": "Get All Cases",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/cases", "host": ["{{base_url}}"], "path": ["api", "cases"] }
          }
        },
        {
          "name": "Create Case",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Urgent Food Supply\",\n  \"description\": \"Need food for a family of 4\",\n  \"fullDescription\": \"A family of 4 in Medenine lost their income and needs urgent food supplies for the week.\",\n  \"governorate\": \"Medenine\",\n  \"city\": \"Zarzis\",\n  \"latitude\": 33.5,\n  \"longitude\": 11.1,\n  \"category\": \"FOOD\",\n  \"victimName\": \"Ahl Medenine\",\n  \"victimPhone\": \"21650123456\",\n  \"creatorName\": \"Volunteer\",\n  \"creatorPhone\": \"21620123456\",\n  \"creatorEmail\": \"volunteer@example.com\",\n  \"peopleAffected\": 4\n}"
            },
            "url": { "raw": "{{base_url}}/api/cases", "host": ["{{base_url}}"], "path": ["api", "cases"] }
          }
        },
        {
          "name": "Offer Help on Case",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/cases/CASE_ID_HERE/help", "host": ["{{base_url}}"], "path": ["api", "cases", "CASE_ID_HERE", "help"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/stats", "host": ["{{base_url}}"], "path": ["api", "stats"] }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        }
      ]
    },
    {
      "name": "Chatbot",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"12345\",\n  \"message\": \"comment s'inscrire?\",\n  \"language\": \"fr\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/chatbot", "host": ["{{base_url}}"], "path": ["api", "chatbot"] }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
